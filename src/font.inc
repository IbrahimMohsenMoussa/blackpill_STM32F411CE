; ====================================================================
; fonts.asm - Read-Only Font Tables
; @Description: Standard 5x7 ASCII Font (Characters 0x20 to 0x7E)
; ====================================================================

    AREA |.rodata|, DATA, READONLY, ALIGN=2
    EXPORT Font5x7

; ----------------------------------------------------------------------------
