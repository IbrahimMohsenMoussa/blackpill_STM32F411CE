    DCB 0x00, 0x08, 0x36, 0x41, 0x00 ; 0x7B {
    DCB 0x00, 0x00, 0x7F, 0x00, 0x00 ; 0x7C |
    DCB 0x00, 0x41, 0x36, 0x08, 0x00 ; 0x7D }
